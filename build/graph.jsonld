    {
      "@id": "https://alexanarch.org#journal-mmrs",
      "@type": "schema:Periodical",
      "schema:name": "Machine-Mediated Reception Studies",
      "schema:alternateName": "MMRS",
      "schema:description": "The formally chartered research field whose object of study is how digital platforms and AI systems receive, transform, transmit, and exclude scholarly content. Founded 2025.",
      "schema:isPartOf": {
        "@id": "https://alexanarch.org"
      }
    },
    {
      "@id": "https://alexanarch.org#journal-trans-sei",
      "@type": "schema:Periodical",
      "schema:name": "Transactions of the Semantic Economy Institute",
      "schema:alternateName": "Trans. SEI",
      "schema:description": "Research into the structure of meaning as an economic and physical system: semantic physics, the Constitution of the Semantic Economy, operative semiotics, and the formal architecture of how value is created, stored, and exchanged through signification.",
      "schema:isPartOf": {
        "@id": "https://alexanarch.org"
      }
    },
    {
      "@id": "https://alexanarch.org#journal-trans-substrate",
      "@type": "schema:Periodical",
      "schema:name": "Transactions in Substrate Engineering",
      "schema:alternateName": "Trans. Substrate Eng.",
      "schema:description": "Engineering work on AI substrates as scholarly instruments: Assembly Chorus methodology, cross-model verification, TACHYON continuity, session architecture, and the operational practice of building reliable epistemic infrastructure from language model interactions.",
      "schema:isPartOf": {
        "@id": "https://alexanarch.org"
      }
    },
    {
      "@id": "https://alexanarch.org#journal-grammata",
      "@type": "schema:Periodical",
      "schema:name": "Grammata: Journal of Operative Philology",
      "schema:alternateName": "Grammata",
      "schema:description": "Philological scholarship treated as an operative practice: close reading as world-making, the letter as material force, and the ancient text as live epistemic instrument. Covers Revelation First, Sappho/Catullus alignment, Pearl, and the broader tradition of heteronymic literary practice.",
      "schema:isPartOf": {
        "@id": "https://alexanarch.org"
      }
    },
    {
      "@id": "https://alexanarch.org#journal-provence",
      "@type": "schema:Periodical",
      "schema:name": "Provence: Studies in Provenance and Attribution",
      "schema:alternateName": "Provence",
      "schema:description": "Research into the provenance chain — how authorship, attribution, and identity survive or are severed across platform transitions, metadata systems, and AI mediation. Named for the region and the root: provenance, proving, the place from which a thing comes.",
      "schema:isPartOf": {
        "@id": "https://alexanarch.org"
      }
    },
    {
      "@id": "https://alexanarch.org#journal-cha",
      "@type": "schema:Periodical",
      "schema:name": "Crimson Hexagonal Archive: Journal",
      "schema:alternateName": "CHA",
      "schema:description": "The archive's own journal — self-reflective documents about the CHA itself: its history, governance, operational records, the Space Ark, and works that are about the archive as a total intellectual project rather than any single research domain within it.",
      "schema:isPartOf": {
        "@id": "https://alexanarch.org"
      }
    },
    {
      "@id": "https://alexanarch.org#journal-compression",
      "@type": "schema:Periodical",
      "schema:name": "Compression Studies",
      "schema:alternateName": "Compression Studies",
      "schema:description": "Research into information compression as a scholarly and aesthetic practice: how large bodies of work survive reduction, what is preserved and lost in compression, and the formal study of holographic encoding in text.",
